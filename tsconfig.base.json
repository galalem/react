{
  "compilerOptions": {
    // tsup injects a (deprecated) `baseUrl` during .d.ts generation; TS 6+ errors
    // on it (TS5101). This tolerates the deprecated option without setting it.
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}